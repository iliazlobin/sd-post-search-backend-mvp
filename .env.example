# Post Search MVP — Configuration
# Copy to .env and adjust, or set via environment variables.
# When running under Docker Compose, settings come from docker-compose.yml's environment: block
# — no local .env needed.

# Database
DATABASE_URL=postgresql+asyncpg://postsearch:postsearch@db:5432/postsearch

# Secret key for HMAC-signed page tokens
SECRET_KEY=change-me-to-a-random-secret

# App
APP_PORT=8000
