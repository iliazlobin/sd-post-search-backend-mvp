# Post Search MVP — Environment Variables
# Copy to .env and override as needed:
#   cp .env.example .env
#
# DATABASE_URL is set in docker-compose.yml's environment block for
# the compose network.  Override here only if running outside compose.

# Database
# DATABASE_URL=postgresql+asyncpg://postsearch:postsearch@db:5432/postsearch

# HMAC secret for cursor pagination tokens
# SECRET_KEY=change-me-in-production

# Host port for the app container (used by docker-compose.yml)
# APP_PORT=8050
